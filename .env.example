# ===== AI Task Assistant 配置 =====

# 访问本工具的登录密码(自己用,设一个强密码)
APP_PASSWORD=change-me-to-a-strong-password

# Session 加密密钥(随机长字符串,不要泄露)
SECRET_KEY=change-me-to-a-random-long-string

# ===== Vikunja =====
# Vikunja 地址(末尾不要加 /),例如 http://127.0.0.1:3456
VIKUNJA_URL=http://127.0.0.1:3456
# Vikunja API Token(在 Vikunja 设置里生成)
VIKUNJA_TOKEN=your_vikunja_api_token

# ===== LLM =====
# OpenAI 兼容的 API 地址(到 /v1)
LLM_BASE_URL=http://your-llm-host:port/v1
LLM_API_KEY=your_llm_api_key
LLM_MODEL=deepseek-v4-flash

# 发给 LLM 的近期任务条数上限
MAX_CONTEXT_TASKS=30

# 任务截止日期所用时区(用户所在时区,影响 due_date 在 Vikunja 里的显示)
# Docker 容器默认 UTC,不设此项会导致截止日期时间偏移
APP_TIMEZONE=Asia/Shanghai
